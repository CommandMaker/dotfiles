[colors]
background = #801f1f2e
background-alt = #BF2e3440
foreground = #ffffff
foreground-alt = #ffffff
primary = #f5c2e7 
secondary = #8fbcbb
alert = #5e81ac

; Modules Prefix Colors
pulseaudio-background=#565f89
cpu-background=#a6e3a1
battery-background=#04293A
packages-background=#e5c890
ram-background=#89b4fa
time-background=#f5c2e7 
powermenu-background=${colors.background}
xwindow-background=#041C32


[bar/customBar]
width = 100%
height = 35
radius = 10
fixed-center = true

background = ${colors.background} 
foreground = ${colors.foreground}

line-size = 3pt
line-color = ${colors.primary}

border-size = 5pt
margin-left = 20pt
border-radius = 10
border-color = #00000000

padding-left = 3
padding-right = 5

module-margin = 2

font-0 = fixed:pixelsize=10;1
font-1 = FontAwesome:style=Regular:pixelsize=11;2
font-2 = unifont:fontformat=truetype:size=10:antialias=true;0
font-3 = "SauceCodePro Nerd Font Mono:style=Regular:size=20;5"

;font-2 = siji:pixelsize=10;1
;font- = "SauceCodePro Nerd Font Mono:style=Medium,Regular:size=30;5"
;font-3 = Font Awesome 5 Free:pixelsize=12;2
;font-4 = Font Awesome 5 Free Solid:pixelsize=12;2
;font-5 = Font Awesome 5 Brands:pixelsize=12;2

modules-left =  i3 
modules-center = xwindow
modules-right = pulseaudio cpu memory date

tray-position = right
tray-padding = 2
tray-detached = false
tray-offset-x = -12
; tray-transparent=true
tray-background = ${colors.background}

cursor-click = pointer
cursor-scroll = ns-resize


[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%

format=<label>

format-prefix= " Óā≤"
format-prefix-background=${colors.background}
format-prefix-foreground=${colors.xwindow-background}
format-background=${colors.xwindow-background}

format-suffix= "Óāį"
format-suffix-background=${colors.background}
format-suffix-foreground=${colors.xwindow-background}


[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "ÓČĮ "

format-prefix-foreground = ${colors.foreground-alt}
format-prefix-underline = ${colors.secondary}

label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
label-indicator-underline = ${colors.secondary}

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %index%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 2

; Separator in between workspaces
; label-separator = |

[module/i3]
type = internal/i3
format = <label-state> <label-mode>

;format-suffix= "Óāį"
;format-suffix-background=${colors.background}
;format-suffix-foreground=${colors.pulseaudio-background}
;format-background=${colors.background}

index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true
ws-icon-0 = 1;Ôäô
ws-icon-1 = 2;ÔĄ†
ws-icon-2 = 3;ÔČ©
ws-icon-3 = 4;Ôäô
ws-icon-4 = 5;ÔāÜ
ws-icon-5 = 6;Ôáď
ws-icon-6 = 7;ÔČ©
ws-icon-7 = 8;ÔÜľ
ws-icon-8 = 8;ÔĀľ

label-mode-padding = 2
label-mode-foreground = #000
;label-mode-background = ${colors.primary}

; focused = Active workspace on focused monitor
label-focused = %icon%
;label-focused-background = ${colors.pulseaudio-background}
label-focused-underline= ${colors.primary}
label-focused-padding = 2


; unfocused = Inactive workspace on any monitor
label-unfocused = %icon%
label-unfocused-padding = 2
;label-unfocused-background = ${colors.pulseaudio-background}

; visible = Active workspace on unfocused monitor
label-visible = %icon%
;label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %icon%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

; Separator in between workspaces
; label-separator = |

[module/spotify]
type = custom/script
tail = true
; prefix symbol is shown before the text
format-prefix = "SPT "
format = <label>
exec = ~/.config/polybar/scripts/scroll_spotify_status.sh

[module/spotify-prev]
type = custom/script
exec = echo <previous-song-symbol>
format = <label>
click-left = playerctl previous -p spotify

[module/spotify-play-pause]
type = custom/ipc
hook-0 = echo <playing-symbol>
hook-1 = echo <pause-symbol>
initial = 1
click-left = playerctl play-pause -p spotify

[module/spotify-next]
type = custom/script
exec = echo "next-song-symbol"
format = <label>
click-left = playerctl next -p spotify


[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = ÓāĖ
icon-stop = Óāô
icon-play = Óāö
icon-pause = Óāõ
icon-next = Óāú

label-song-maxlen = 25
label-song-ellipsis = true

[module/xbacklight]
type = internal/xbacklight

format =<label> 
format-prefix = "ÔÜÖ "
label = %percentage%%

bar-width = 10
bar-indicator = |
bar-indicator-foreground = #fff
bar-indicator-font = 2
bar-fill = ‚ĒÄ
bar-fill-font = 2
bar-fill-foreground = #9f78e1
bar-empty = ‚ĒÄ
bar-empty-font = 2
bar-empty-foreground = ${colors.foreground-alt}


[module/cpu]
type = internal/cpu
interval = 2

format-prefix="  "
format-suffix="  "

format=Ôčõ <label>
label = %percentage:2%%

format-underline = ${colors.cpu-background}


[module/memory]
type = internal/memory
interval = 2

label = ÔáÄ  %percentage_used%% | %gb_used%
format-underline = ${colors.ram-background}


[module/wlan]
type = internal/network
interface = wlo1
interval = 3.0

format-connected =<ramp-signal> <label-connected>

format-connected-prefix="Óā≤"
format-connected-suffix="  "
format-connected-prefix-background=${colors.battery-background}

label-connected = %essid%

format-disconnected = <label-disconnected>
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}
ramp-signal-0 = Óąė
ramp-signal-1 = Óąô
ramp-signal-2 = Óąö
ramp-signal-3 = Óąö
ramp-signal-4 = Óąö
ramp-signal-foreground = ${colors.foreground-alt}

[module/eth]
type = internal/network
interface = enp3s0
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = "ÓÜú "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

; format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/date]
type = internal/date
interval = 5

date = " %d/%m/%Y"
date-alt = " %d/%m/%Y"

time = %H:%M
time-alt = %H:%M

format-underline = ${colors.time-background}

label = ÔÄó %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume =<ramp-volume> <label-volume> 

format-volume-prefix = "  "
format-volume-suffix = " "
format-volume-prefix-foreground=${colors.pulseaudio-background}

;<bar-volume>
ramp-volume-0 = ÔÄ¶
ramp-volume-1 = ÔÄß
ramp-volume-2 = ÔÄ®
label-volume-padding = 2
label-volume = %percentage%%
label-volume-foreground = ${root.foreground}

label-muted = ÔÄ¶x
label-muted-foreground = ${root.foreground}

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

format-volume-underline = #94e2d5
format-muted-underline = #94e2d5

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

format-muted-prefix = "Óąā "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC0
full-at = 98

; Format Charging
format-charging = ÔÉß <label-charging>
format-charging-prefix= " Óā≤"
format-charging-suffix="  "
format-charging-prefix-background=${colors.cpu-background}
format-charging-prefix-foreground=${colors.battery-background}
format-charging-background=${colors.battery-background}

; Format Discharging
format-discharging =ÔČĀ <label-discharging>
format-discharging-suffix="  "
format-discharging-prefix= " Óā≤"
format-discharging-prefix-background=${colors.cpu-background}
format-discharging-prefix-foreground=${colors.battery-background}
format-discharging-background=${colors.battery-background}

format-full-prefix = "Óąļ "
format-full-prefix-foreground = ${colors.foreground-alt}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČā
ramp-capacity-2 = ÔČÄ
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = Óą∂
animation-charging-1 = Óą∑
animation-charging-2 = Óął
